{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MacTTC",
  "version": "0.9.5",
  "identifier": "com.macttc.downloader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MacTTC",
        "width": 900,
        "height": 700,
        "minWidth": 720,
        "minHeight": 680,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
